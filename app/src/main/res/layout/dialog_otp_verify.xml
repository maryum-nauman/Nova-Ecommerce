<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <!-- Lock icon + title -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_marginBottom="20dp">

        <TextView
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:text="🔐"
            android:textSize="32sp"
            android:gravity="center"
            android:background="@drawable/circle_light_overlay"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Payment Verification"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#1A1A2E" />

        <TextView
            android:id="@+id/tvOtpEmail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="OTP sent to your email"
            android:textSize="13sp"
            android:textColor="#888888"
            android:layout_marginTop="4dp"
            android:gravity="center" />

    </LinearLayout>

    <!-- OTP input boxes feel -->
    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:hint="Enter 6-digit OTP"
        app:boxStrokeColor="@color/colorPrimary"
        app:boxStrokeWidthFocused="2dp"
        app:hintTextColor="@color/colorPrimary"
        app:startIconDrawable="@drawable/ic_lock"
        app:startIconTint="@color/colorPrimary">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etOtpCode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="number"
            android:maxLength="6"
            android:textSize="22sp"
            android:textStyle="bold"
            android:letterSpacing="0.3"
            android:gravity="center"
            android:textColor="#1A1A2E" />

    </com.google.android.material.textfield.TextInputLayout>

    <!-- Countdown -->
    <TextView
        android:id="@+id/tvOtpCountdown"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Expires in 05:00"
        android:textSize="12sp"
        android:textColor="#888888"
        android:gravity="center"
        android:layout_marginBottom="16dp" />

    <!-- Progress bar -->
    <ProgressBar
        android:id="@+id/pbOtpVerify"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:indeterminateTint="@color/colorPrimary"
        android:layout_marginBottom="12dp"
        android:visibility="gone" />

    <!-- Verify button -->
    <Button
        android:id="@+id/btnVerifyOtp"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:text="Verify OTP"
        android:textSize="15sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:backgroundTint="@color/colorPrimary"
        android:layout_marginBottom="12dp"
        app:cornerRadius="12dp"
        style="@style/Widget.MaterialComponents.Button" />

    <!-- Resend link -->
    <TextView
        android:id="@+id/tvResendOtp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Resend OTP"
        android:textSize="13sp"
        android:textColor="@color/colorPrimary"
        android:gravity="center"
        android:textStyle="bold"
        android:padding="8dp" />

</LinearLayout>