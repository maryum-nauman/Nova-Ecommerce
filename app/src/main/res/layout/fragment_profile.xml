<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="32dp">

        <!-- ── Header ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="36dp"
            android:paddingBottom="24dp"
            android:background="#FFFFFF">

            <FrameLayout
                android:layout_width="96dp"
                android:layout_height="96dp"
                android:layout_gravity="center">
                <ImageView
                    android:id="@+id/imgAvatar"
                    android:layout_width="96dp"
                    android:layout_height="96dp"
                    android:src="@drawable/ic_person"
                    android:scaleType="centerCrop"
                    android:background="@drawable/circle_avatar_bg"
                    android:clipToOutline="true"/>
                <ImageView
                    android:id="@+id/btnEditAvatar"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_gravity="bottom|end"
                    android:src="@drawable/ic_edit"
                    android:background="@drawable/circle_edit_bg"
                    android:padding="5dp"
                    android:elevation="4dp"/>
            </FrameLayout>

            <TextView
                android:id="@+id/tvUserName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="User Name"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#1A1A2E"/>

            <TextView
                android:id="@+id/tvUserEmail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="user@email.com"
                android:textSize="13sp"
                android:textColor="#9E9E9E"/>
        </LinearLayout>

        <!-- ── Stats Row (4 Columns) ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="12dp"
            android:layout_marginHorizontal="16dp"
            android:background="@drawable/card_rounded"
            android:elevation="2dp"
            android:padding="16dp">

            <LinearLayout
                android:id="@+id/layoutStatOrders"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="?attr/selectableItemBackground">
                <TextView
                    android:id="@+id/tvOrderCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/colorPrimary"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Orders"
                    android:textSize="10sp"
                    android:textColor="#9E9E9E"/>
            </LinearLayout>

            <View android:layout_width="1dp" android:layout_height="30dp" android:layout_gravity="center_vertical" android:background="#E0E0E0"/>

            <LinearLayout
                android:id="@+id/layoutStatFavs"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="?attr/selectableItemBackground">
                <TextView
                    android:id="@+id/tvFavCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/colorPrimary"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Favorites"
                    android:textSize="10sp"
                    android:textColor="#9E9E9E"/>
            </LinearLayout>

            <View android:layout_width="1dp" android:layout_height="30dp" android:layout_gravity="center_vertical" android:background="#E0E0E0"/>

            <LinearLayout
                android:id="@+id/layoutStatCart"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="?attr/selectableItemBackground">
                <TextView
                    android:id="@+id/tvCartCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/colorPrimary"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="In Cart"
                    android:textSize="10sp"
                    android:textColor="#9E9E9E"/>
            </LinearLayout>

            <View android:layout_width="1dp" android:layout_height="30dp" android:layout_gravity="center_vertical" android:background="#E0E0E0"/>

            <LinearLayout
                android:id="@+id/layoutStatReviews"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="?attr/selectableItemBackground">
                <TextView
                    android:id="@+id/tvReviewCountProfile"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/colorPrimary"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Reviews"
                    android:textSize="10sp"
                    android:textColor="#9E9E9E"/>
            </LinearLayout>
        </LinearLayout>

        <!-- ── My Orders Card ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="16dp"
            android:layout_marginHorizontal="16dp"
            android:background="@drawable/card_rounded"
            android:elevation="2dp"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="My Orders"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A2E"/>
                <TextView
                    android:id="@+id/tvViewAllOrders"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="View all ›"
                    android:textSize="13sp"
                    android:textColor="@color/colorPrimary"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="16dp">

                <LinearLayout
                    android:id="@+id/layoutPending"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="?attr/selectableItemBackground">
                    <FrameLayout android:layout_width="48dp" android:layout_height="48dp">
                        <ImageView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:src="@drawable/ic_order_pending"
                            android:padding="10dp"
                            android:background="@drawable/circle_status_bg"/>
                        <TextView
                            android:id="@+id/tvPendingCount"
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:layout_gravity="top|end"
                            android:background="@drawable/circle_badge_bg"
                            android:text="0"
                            android:textSize="10sp"
                            android:textColor="#FFFFFF"
                            android:gravity="center"
                            android:visibility="gone"/>
                    </FrameLayout>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Pending"
                        android:textSize="11sp"
                        android:textColor="#616161"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/layoutShipped"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="?attr/selectableItemBackground">
                    <FrameLayout android:layout_width="48dp" android:layout_height="48dp">
                        <ImageView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:src="@drawable/ic_order_shipped"
                            android:padding="10dp"
                            android:background="@drawable/circle_status_bg"/>
                        <TextView
                            android:id="@+id/tvShippedCount"
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:layout_gravity="top|end"
                            android:background="@drawable/circle_badge_bg"
                            android:text="0"
                            android:textSize="10sp"
                            android:textColor="#FFFFFF"
                            android:gravity="center"
                            android:visibility="gone"/>
                    </FrameLayout>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Shipped"
                        android:textSize="11sp"
                        android:textColor="#616161"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/layoutDelivered"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="?attr/selectableItemBackground">
                    <FrameLayout android:layout_width="48dp" android:layout_height="48dp">
                        <ImageView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:src="@drawable/ic_order_delivered"
                            android:padding="10dp"
                            android:background="@drawable/circle_status_bg"/>
                        <TextView
                            android:id="@+id/tvDeliveredCount"
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:layout_gravity="top|end"
                            android:background="@drawable/circle_badge_bg"
                            android:text="0"
                            android:textSize="10sp"
                            android:textColor="#FFFFFF"
                            android:gravity="center"
                            android:visibility="gone"/>
                    </FrameLayout>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Delivered"
                        android:textSize="11sp"
                        android:textColor="#616161"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- ── Recommended Section ── -->
        <LinearLayout
            android:id="@+id/layoutRecommended"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="24dp"
            android:layout_marginHorizontal="16dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="You Might Also Like"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#1A1A2E"
                android:layout_marginBottom="12dp"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvRecommendedProfile"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
